# OpenVPN client configuration file
# Generated by Chef - local changes will be overwritten!

# Please refer to the OpenVPN documentation for details on
# configuration settings.

client
dev <%= (@config['dev'] || 'tun0').chomp('0') %>
proto <%= @config['proto'] || 'udp' %>
remote <%= @gateway %> <%= @config['port'] || '1194' %>
resolv-retry infinite
nobind
persist-key
persist-tun
ca ca.crt
cert <%= @client_cn %>.crt
key <%= @client_cn %>.key
<% if @compression -%>
compress <%= @compression %>
<% end %>
<% 
%w(cipher tls-cipher auth keysize link-mtu).each do |conf| 
  if @config[conf]
%><%= "#{conf} #{@config[conf]}" %>
<%
  end
end 
-%>
verb 3
<% if @server_verification -%>
<%= @server_verification %>
<% end -%>
